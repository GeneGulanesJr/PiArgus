# smolfier/browser.smolfile
# Headless Chromium microVM for heavy-tier browser operations
# Uses alpine:edge with Chromium installed

image = "alpine:edge"

cpus = 4
memory = 4096
net = true

env = [
    "CHROME_BIN=/usr/bin/chromium",
]

[dev]
init = [
    "apk add --no-cache chromium font-opensans",
]
